<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/anthropic_key_label"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/anthropicKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="sk-ant-..."
            android:inputType="textVisiblePassword"
            android:autofillHints="" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/deepseek_key_label"
            android:paddingTop="16dp"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/deepseekKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="sk-..."
            android:inputType="textVisiblePassword"
            android:autofillHints="" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/orchestrator_model_label"
            android:paddingTop="16dp"
            android:paddingBottom="4dp" />

        <AutoCompleteTextView
            android:id="@+id/leadModel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/lead_model_default"
            android:inputType="text"
            android:completionThreshold="0"
            android:autofillHints="" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/implementer_model_label"
            android:paddingTop="16dp"
            android:paddingBottom="4dp" />

        <AutoCompleteTextView
            android:id="@+id/workerModel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/worker_model_default"
            android:inputType="text"
            android:completionThreshold="0"
            android:autofillHints="" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/github_token_label"
            android:paddingTop="16dp"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/githubToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ghp_..."
            android:inputType="textVisiblePassword"
            android:autofillHints="" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/agent_branch_label"
            android:paddingTop="16dp"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/agentBranch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/agent_branch_default"
            android:inputType="text"
            android:autofillHints="" />

    </LinearLayout>

</ScrollView>
